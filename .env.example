# CartolaPy Environment Configuration

# Redis Configuration
# Format: redis://:password@host:port
# IMPORTANT: Password is required in production
REDIS_PASSWORD=your_redis_password_here

# API Security Keys
# Generate secure keys: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_api_key_here
ADMIN_API_KEY=your_admin_api_key_here

# AI report generation for "Dicas da Rodada"
OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
DICAS_MODEL=openai:gpt-5.5
DICAS_REASONING_EFFORT=medium
CARTOLAPY_API_BASE_URL=http://localhost:8000

# AWS S3 persistence for Dicas reports and round memories
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
DICAS_S3_BUCKET=your_cartolapy_dicas_bucket_here
DICAS_S3_PREFIX=cartolapy/dicas-da-rodada
DICAS_SEASON_YEAR=2026
DICAS_MEMORY_LOOKBACK_ROUNDS=38
DICAS_MEMORY_CONTEXT_ROUNDS=5

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=cartolapy-dicas

# Environment
ENVIRONMENT=production

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:8501
